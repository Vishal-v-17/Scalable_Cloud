files:
  "/etc/nginx/conf.d/security.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Block access to sensitive files
      location ~* /\.env {
        deny all;
        return 404;
      }
      location ~* /\.git {
        deny all;
        return 404;
      }
      location ~* /~[a-z]+ {
        deny all;
        return 404;
      }
